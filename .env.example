# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── OPTIONAL ────────────────────────────────────────────────────────────────
# How often to check for new posts (in seconds). Default: 300 (5 min)
CHECK_INTERVAL_SECONDS=300
